{
  "manifest_version": 2,
  "name": "Bookmark Saver",
  "version": "1.0",
  "description": "Save the current page to your local bookmarks server.",
  "permissions": ["activeTab", "tabs", "http://localhost/*"],
  "browser_specific_settings": {
    "gecko": {
      "id": "bookmark-saver@localhost"
    }
  },
  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "Save this page"
  }
}
