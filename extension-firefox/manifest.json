{
  "manifest_version": 2,
  "name": "Bookmark Saver",
  "version": "1.0",
  "description": "Save the current page to your local bookmarks server.",
  "permissions": ["activeTab", "tabs", "bookmarks", "http://localhost:8484/*"],
  "background": { "scripts": ["background.js"] },
  "content_scripts": [
    { "matches": ["http://localhost:8484/*"], "js": ["content_script.js"] }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "bookmark-saver@localhost"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "Save this page",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
