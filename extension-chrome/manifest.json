{
  "manifest_version": 3,
  "name": "Bookmark Saver",
  "version": "1.0",
  "description": "Save the current page to your local bookmarks server.",
  "permissions": ["activeTab", "tabs", "bookmarks"],
  "host_permissions": ["http://localhost:8484/*"],
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    { "matches": ["http://localhost:8484/*"], "js": ["content_script.js"] }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Save this page",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
